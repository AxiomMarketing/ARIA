{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ARIA",
  "scopeName": "source.aria",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.aria",
          "match": "---.*$"
        },
        {
          "name": "comment.line.double-dash.aria",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aria",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.aria", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.aria",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.aria", "match": "\\\\." }
          ]
        }
      ]
    },
    "regex": {
      "name": "string.regexp.aria",
      "begin": "(?<=matches\\s)/",
      "end": "/",
      "patterns": [
        { "name": "constant.character.escape.aria", "match": "\\\\." }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.aria",
          "match": "\\b\\d[\\d_]*\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.aria",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.declaration.aria",
          "match": "\\b(module|type|contract|behavior|import|from)\\b"
        },
        {
          "name": "keyword.control.section.aria",
          "match": "\\b(inputs|requires|ensures|on_failure|examples|effects|depends_on|timeout|retry|steps|compensate|rate_limit|states|transitions|invariants|forbidden|initial)\\b"
        },
        {
          "name": "keyword.control.flow.aria",
          "match": "\\b(when|return|with|given|then|flow|of|is|where|version|target|author)\\b"
        },
        {
          "name": "keyword.operator.logical.aria",
          "match": "\\b(and|or|not|implies|in|valid|matches|starts_with|exists|once|increased_by)\\b"
        },
        {
          "name": "keyword.other.effect.aria",
          "match": "\\b(sends|writes|creates|reads|deletes)\\b"
        },
        {
          "name": "keyword.other.retry.aria",
          "match": "\\b(max|backoff|on_exhaust|exponential|linear|constant|per|seconds|minutes|hours|days)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.primitive.aria",
      "match": "\\b(Integer|Decimal|String|Boolean|DateTime|Record|Enum|List)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.aria",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.arithmetic.aria",
          "match": "\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.arrow.aria",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.aria",
          "match": "="
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.aria",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.self.aria",
          "match": "\\b(self|result|old|length|now)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.aria",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.aria",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
